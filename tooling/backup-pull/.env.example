# Cau hinh script keo backup offsite. Copy thanh `.env` canh script.
# (hoac dat truc tiep lam bien moi truong / tham so dong lenh)

# URL server prod (khong dau / cuoi).
SERVER_URL=https://erp.vfmgroup.vn

# API key co scope backup:full — tao o Cai dat -> API Keys, loai "Sao luu (MCP)" muc "full".
# GIU BI MAT: key nay tai duoc TOAN BO du lieu (moi tenant).
API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx

# Thu muc luu backup tren may offsite.
OUT_DIR=/var/backups/erp

# So ban moi nhat giu lai moi loai (db + uploads). Cu hon se bi xoa.
KEEP=14

# Timeout 1 lan tai (giay). DB lon -> tang len.
TIMEOUT=1800
