# =============================================================
# packages/server/.env.example
# Sao chép thành packages/server/.env rồi điền giá trị thật.
# Không commit file .env thật lên git.
# Tạo nhanh: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================

# ── Database ──────────────────────────────────────────────────
# Bắt buộc. Kết nối PostgreSQL 18 + pgvector.
DATABASE_URL=postgres://erp:erp@localhost:5432/erp_framework

# Tuỳ chọn: read replica (để trống = dùng DATABASE_URL cho cả đọc/ghi)
# DATABASE_URL_READ=postgres://erp:erp@replica:5432/erp_framework

# Tuỳ chọn: sharding — JSON array connection string
# DATABASE_URL_SHARDS=[{"id":"s1","url":"postgres://..."},{"id":"s2","url":"postgres://..."}]

# ── Server ────────────────────────────────────────────────────
PORT=8910
HOST=127.0.0.1

# NODE_ENV: development | production
# Production bật cookie secure + bắt buộc CORS_ORIGIN + ENCRYPTION_KEY.
NODE_ENV=development

# ── Bảo mật ──────────────────────────────────────────────────
# Bắt buộc ở production. Dùng để mã hoá API key LLM, token tool proxy.
# AES-256-GCM cần 32-byte hex. Sinh: openssl rand -hex 32
ENCRYPTION_KEY=doi-thanh-chuoi-ngau-nhien-dai-it-nhat-32-ky-tu

# Bắt buộc ở production. Danh sách origin được phép gọi API (CORS).
# Dev local để trống = cho phép mọi origin.
# CORS_ORIGIN=https://app.example.com

# ── File upload ───────────────────────────────────────────────
# Thư mục lưu file Knowledge Base (PDF, DOCX...).
# Docker: volume erp-uploads mount vào /data/uploads.
# Dev local: đặt thư mục tuyệt đối trên máy (tự tạo nếu chưa có).
UPLOAD_DIR=/data/uploads

# ── Tika (trích văn bản từ PDF/DOCX) ─────────────────────────
# Mặc định kết nối Tika Docker. Dev: pnpm db:up rồi docker compose up tika
TIKA_URL=http://localhost:9998

# ── Bản vẽ + FreeCAD CAD (Agent vẽ bản vẽ) ───────────────────
# Thư mục lưu bản vẽ (gồm "Bản vẽ AI" sinh ra). BẮT BUỘC nếu dùng tính
# năng sinh bản vẽ CAD (không có = persistDrawing báo lỗi). GET /banvesvc/file
# stream từ đây.
BANVE_FILES_DIR=/data/banve
# FreeCAD MCP sidecar (provider 1). Vắng = tool cad_generate không bật.
# FREECAD_MCP_URL=http://localhost:8920
# FREECAD_MCP_SECRET=please-change-this-freecad-secret

# ── MQTT / IoT ────────────────────────────────────────────────
# Để trống = tắt IoT MQTT hoàn toàn.
# MQTT_URL=mqtt://localhost:1883
# MQTT_USERNAME=
# MQTT_PASSWORD=

# ── LLM / AI ──────────────────────────────────────────────────
# Mặc định LLM config lưu trong DB (Settings → LLM).
# Bật env fallback CHỈ cho môi trường dev/test (tránh leak tenant isolation).
# ERP_ALLOW_ENV_LLM_KEY=1
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── Tool proxy ────────────────────────────────────────────────
# HMAC secret để ký header X-ERP-User-Id/Company-Id/Role khi forward đến tool.
# Sinh: openssl rand -hex 32
# Để trống = tool proxy không ký (không an toàn ở production).
# TOOL_SIGNING_SECRET=

# Thư mục chứa Tools artifact (auto-scan khi khởi động).
# TOOLS_DIR=D:\code\cowok\Tools

# Cho phép đăng ký tool remote từ IP private/loopback (chỉ dùng nội bộ).
# TOOLS_ALLOW_PRIVATE_REMOTE=1

# ── Code execution (isolated-vm) ─────────────────────────────
# Giới hạn tài nguyên khi chạy Procedure / Workflow code người dùng viết.
CODE_NODE_MEM_MB=128
CODE_NODE_TIMEOUT_MS=5000
# Allowlist domain fetch trong sandbox (phân cách bằng dấu phẩy).
# Để trống = chặn mọi network call từ sandbox.
# CODE_NODE_FETCH_ALLOWLIST=https://api.example.com

# ── Workflow ──────────────────────────────────────────────────
WORKFLOW_TIMEOUT_MS=300000

# ── WebSocket / Redis (tuỳ chọn) ─────────────────────────────
# Để trống = dùng in-process pub/sub (không scale multi-instance).
# REDIS_URL=redis://localhost:6379
