# =============================================================
# packages/server/.env.no-docker.example
# Template cho DEV KHÔNG cài Docker (máy yếu / OS không hỗ trợ).
#
# Cách dùng:
#   1. Copy file này thành packages/server/.env
#   2. Copy DATABASE_URL y hệt sang packages/db/.env (drizzle migrate đọc đó)
#   3. Điền connection string Postgres remote (Neon/Supabase/server LAN)
#   4. pnpm install
#      pnpm --filter @erp-framework/db migrate
#      pnpm --filter @erp-framework/server seed
#      pnpm dev        # app: http://localhost:5173 · server: 8910
#
# ⚠ KHÔNG chạy `pnpm db:setup` / `pnpm dev:setup` ở chế độ này —
#   cả hai check `docker --version` và exit ngay. Làm tay 3 bước trên.
# =============================================================

# ── Database (BẮT BUỘC — phụ thuộc cứng duy nhất) ─────────────
# Postgres 18 PHẢI có extension pgvector (migration 0007 chạy
# `CREATE EXTENSION vector`). Neon/Supabase bật sẵn; PG tự dựng
# thì cài pgvector trước, nếu không migrate sẽ đỏ.
#
# ⚠ sslmode KHÁC NHAU GIỮA 2 FILE khi DB dùng cert TỰ KÝ (vd hạ tầng
#   docker/docker-compose.dev-infra.yaml) — vì 2 driver hiểu khác nhau:
#   • file NÀY (packages/server/.env, driver postgres-js): ?sslmode=require
#   • packages/db/.env (drizzle-kit migrate, driver pg):    ?sslmode=no-verify
#   Dùng nhầm → 1 trong 2 báo "self-signed certificate" và fail.
#   ⚠ self-signed + require/no-verify = MÃ HOÁ đường truyền nhưng KHÔNG
#     chống MITM. Chống MITM → cert THẬT cho host (vd Let's Encrypt) rồi
#     cả 2 file dùng ?sslmode=verify-full. (LAN nội bộ không TLS: bỏ ?sslmode.)
DATABASE_URL=postgres://erp:<SERVICE_PASSWORD_64_DB>@db.vfmgroup.vn:55432/erp_framework?sslmode=require

# Tuỳ chọn: read replica (để trống = dùng DATABASE_URL cho cả đọc/ghi)
# DATABASE_URL_READ=

# ── Server ────────────────────────────────────────────────────
PORT=8910
HOST=127.0.0.1
# development = cookie không secure + CORS/ENCRYPTION_KEY không bắt buộc.
NODE_ENV=development

# ── Bảo mật ──────────────────────────────────────────────────
# Ở dev (NODE_ENV=development) KHÔNG bắt buộc, nhưng nên có để mã hoá
# API key LLM lưu trong DB ở dạng enc:v1: (xem CLAUDE.md mục 4).
# Sinh 32-byte hex:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=

# Dev local để TRỐNG = cho phép mọi origin (vite ở :5173 gọi server :8910 OK).
# CORS_ORIGIN=

# ── File upload (Knowledge Base) ──────────────────────────────
# Không có volume Docker → trỏ về thư mục cục bộ (tự tạo nếu chưa có).
# Đường dẫn tương đối tính từ cwd server = packages/server.
UPLOAD_DIR=./.uploads

# ── Tika — TẮT mặc định ───────────────────────────────────────
# Để trống = KB không trích văn bản PDF/DOCX, phần còn lại app vẫn chạy.
# Nếu deploy hạ tầng dev-infra (Coolify), trỏ theo domain + port:
# Qua Caddy basic-auth (dev-infra) → nhét user:pass vào URL (server tự
# chuyển thành header Authorization):
# TIKA_URL=http://dev:<SERVICE_PASSWORD_64_PROXY>@tika.vfmgroup.vn:59998

# ── Bản vẽ + FreeCAD CAD (Agent vẽ bản vẽ) ───────────────────
# Thư mục lưu bản vẽ (gồm "Bản vẽ AI" sinh ra). Đường dẫn cục bộ ghi được
# (tự tạo). BẮT BUỘC nếu dùng sinh bản vẽ CAD.
BANVE_FILES_DIR=./.banve
# Provider 2a (local-dev, KHÔNG Docker): cài FreeCAD native trên máy này,
# rồi chạy bridge:  python3 tooling/freecad-mcp/server.py  (đặt FREECADCMD
# nếu freecadcmd không trên PATH). Server gọi 127.0.0.1 trực tiếp:
# FREECAD_MCP_URL=http://127.0.0.1:8920
# FREECAD_MCP_SECRET=please-change-this-freecad-secret

# ── MQTT / IoT — TẮT mặc định ─────────────────────────────────
# Để trống = tắt IoT MQTT hoàn toàn. Nếu bật service mosquitto của
# dev-infra (có mật khẩu): MQTT_URL=mqtt://dev:<SERVICE_PASSWORD_64_MQTT>@mqtt.vfmgroup.vn:51883
# MQTT_URL=

# ── LLM / AI ──────────────────────────────────────────────────
# Mặc định LLM/Embedding config lưu trong DB: vào app → Cài đặt → LLM,
# nhập API key Anthropic/OpenAI. Đây là cách CHUẨN (tenant-isolated).
#
# Không có Ollama → đừng chọn embedding Ollama; dùng OpenAI embedding
# hoặc tạm bỏ trống (Knowledge Base vector search sẽ không hoạt động
# tới khi cấu hình embedding).
# Có Ollama từ dev-infra (Coolify) → app → Cài đặt → Embedding, endpoint:
#   http://ollama.vfmgroup.vn:51434  · model nomic-embed-text (qua Caddy
#   basic-auth → endpoint cần user:pass: http://dev:<pw>@ollama.vfmgroup.vn:51434)
# (hoặc đặt OLLAMA_EMBED_URL=http://dev:<SERVICE_PASSWORD_64_PROXY>@ollama.vfmgroup.vn:51434)
#
# Chỉ cho máy dev CÁ NHÂN: bật fallback đọc key từ env (KHÔNG dùng ở
# môi trường nhiều tenant — leak isolation, xem CLAUDE.md mục 4 + 6).
# ERP_ALLOW_ENV_LLM_KEY=1
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── Claude CLI Bridge — TẮT ───────────────────────────────────
# Không set BRIDGE_URL → server fallback localhost (xem comment ở
# docker-compose service "server"). Chỉ cần khi dùng LLM adapter
# claude-cli; muốn dùng thì chạy `pnpm bridge` trên host rồi:
# BRIDGE_URL=http://localhost:8909

# ── Tool proxy ────────────────────────────────────────────────
# Để trống = không ký HMAC (chỉ chấp nhận ở dev). Sinh khi cần:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TOOL_SIGNING_SECRET=

# ── Code execution (isolated-vm) ─────────────────────────────
CODE_NODE_MEM_MB=128
CODE_NODE_TIMEOUT_MS=5000
# Để trống = chặn mọi network call từ sandbox.
# CODE_NODE_FETCH_ALLOWLIST=

# ── Workflow ──────────────────────────────────────────────────
WORKFLOW_TIMEOUT_MS=300000

# ── Tìm kiếm web (SearXNG) — TẮT mặc định ─────────────────────
# Để trống = công cụ web_search + node workflow "Web Search" + web
# fallback của Tìm sâu (Deep RAG) không hoạt động (app vẫn chạy bình thường).
# Ưu tiên cấu hình per-company ở app → Cài đặt → Tìm kiếm web; env này
# là fallback toàn deployment. SearXNG phải bật `json` trong search.formats.
# Sau reverse-proxy basic-auth (vd dev-infra Caddy) → nhét user:pass vào URL:
# SEARXNG_URL=http://dev:<SERVICE_PASSWORD_64_PROXY>@searxng.vfmgroup.vn:58080
# Local tự host: SEARXNG_URL=http://127.0.0.1:8080

# ── WebSocket / Redis — TẮT ───────────────────────────────────
# Để trống = pub/sub in-process (đủ cho dev 1 instance).
# REDIS_URL=
