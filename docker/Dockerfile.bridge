# Claude Code CLI Bridge — chạy claude CLI bên trong container, expose HTTP :8909.
# App (ClaudeCliAdapter chạy trong trình duyệt) gọi tới đây để dùng claude CLI
# làm nguồn LLM — tận dụng đăng nhập Pro/Max thay vì API key.
FROM node:22-slim

# git + ca-certificates: claude code cần để hoạt động trơn tru.
RUN apt-get update && apt-get install -y --no-install-recommends \
      git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Cài Claude Code CLI toàn cục.
RUN npm install -g @anthropic-ai/claude-code

WORKDIR /app
# Bridge chỉ là 1 file .mjs dùng toàn node built-in — copy mình nó là đủ.
COPY scripts/claude-bridge.mjs ./claude-bridge.mjs

# Toàn bộ trạng thái nằm dưới /data (một volume) để KHÔNG mất khi rebuild:
#  - /data/claude  : CLAUDE_CONFIG_DIR — claude CLI gom HẾT config + credentials
#                    + .claude.json vào đây (thay vì rải ở ~/.claude và ~/.claude.json).
#  - /data/bridge  : CONFIG_DIR — kho config của bridge script.
RUN mkdir -p /data/claude /data/bridge \
    && chown -R node:node /data /app
USER node

# HOST=0.0.0.0 để cổng reachable qua published port.
ENV HOST=0.0.0.0 \
    PORT=8909 \
    CONFIG_DIR=/data/bridge \
    CLAUDE_CONFIG_DIR=/data/claude

EXPOSE 8909
CMD ["node", "/app/claude-bridge.mjs"]
