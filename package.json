{
  "name": "erp-framework",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n app,server -c blue,green \"vite\" \"pnpm --filter @erp-framework/server dev\"",
    "dev:app": "vite",
    "dev:server": "pnpm --filter @erp-framework/server dev",
    "dev:setup": "node tooling/dev-setup.mjs",
    "build": "tsc && vite build",
    "typecheck": "tsc",
    "preview": "vite preview",
    "lint": "biome check src",
    "format": "biome format --write src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "bridge": "node scripts/claude-bridge.mjs",
    "new:plugin": "node tooling/create-plugin.mjs",
    "db:setup": "node tooling/setup-db.mjs",
    "db:up": "docker compose -f docker/docker-compose.yml up -d db",
    "db:down": "docker compose -f docker/docker-compose.yml stop db",
    "db:migrate": "pnpm --filter @erp-framework/db migrate",
    "e2e": "playwright test",
    "e2e:full": "node tooling/e2e-full.mjs",
    "backup": "node tooling/backup.mjs",
    "restore": "node tooling/restore.mjs"
  },
  "dependencies": {
    "@erp-framework/core": "workspace:*",
    "@erp-framework/client": "workspace:*",
    "@erp-framework/plugins": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@tanstack/react-router": "^1.95.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-table": "^8.20.0",
    "zustand": "^5.0.2",
    "react-hook-form": "^7.54.0",
    "@hookform/resolvers": "^3.10.0",
    "zod": "^3.24.0",
    "@xyflow/react": "^12.4.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "lucide-react": "^0.460.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.0",
    "class-variance-authority": "^0.7.1",
    "idb": "^8.0.0",
    "recharts": "^2.15.0",
    "leaflet": "^1.9.4",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/leaflet": "^1.9.12",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "@tanstack/router-vite-plugin": "^1.95.0",
    "vite": "^6.0.0",
    "typescript": "^5.7.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.5.0",
    "@biomejs/biome": "^1.9.0",
    "vitest": "^2.1.0",
    "@testing-library/react": "^16.1.0",
    "@playwright/test": "^1.48.0",
    "concurrently": "^9.1.0"
  }
}
